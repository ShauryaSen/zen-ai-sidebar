{
  "manifest_version": 2,
  "name": "Zen AI Sidebar",
  "version": "1.1.0",
  "description": "AI-powered sidebar for Zen Browser using Gemini API. Summarize pages, explain selections, and ask contextual questions.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "sidebar_action": {
    "default_title": "Zen AI",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Toggle Zen AI Sidebar"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "<all_urls>",
    "theme"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content/youtube-transcript.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "themes/catppuccin-latte.json",
    "themes/catppuccin-frappe.json",
    "themes/catppuccin-macchiato.json",
    "themes/catppuccin-mocha.json"
  ],
  "background": {
    "scripts": ["background/background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zen-ai-sidebar@extension",
      "strict_min_version": "109.0"
    }
  }
}
